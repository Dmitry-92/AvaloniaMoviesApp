<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AvaloniaMoviesApp.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="AvaloniaMoviesApp.Views.MainWindow"
        Title="Библиотека фильмов"
        Width="900" Height="600"
        MinWidth="700" MinHeight="500">

    <DockPanel>
        <!-- Верхняя панель с кнопками -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10" Spacing="10">
            <Button Name="AddButton" Content="➕ Добавить фильм" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="EditButton" Content="✏️ Редактировать" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="DeleteButton" Content="🗑️ Удалить" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="RefreshButton" Content="🔄 Обновить" HorizontalAlignment="Left" MinWidth="100"/>
        </StackPanel>

        <!-- Список фильмов с шапкой -->
        <StackPanel Margin="10">
            <!-- Шапка таблицы -->
            <Border Background="LightGray" Padding="10" Margin="0,0,0,2">
                <Grid ColumnDefinitions="50,*,150,80,120,80">
                    <TextBlock Text="ID" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Название" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Режиссёр" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Год" Grid.Column="3" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Жанр" Grid.Column="4" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Рейтинг" Grid.Column="5" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            
            <!-- Список фильмов -->
            <ListBox Name="MoviesListBox" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:Movie">
                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10" Margin="0,2">
                            <Grid ColumnDefinitions="50,*,150,80,120,80">
                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Director}" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Year}" Grid.Column="3" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Genre}" Grid.Column="4" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Rating, StringFormat='{}{0:F1}'}" Grid.Column="5" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </DockPanel>
</Window>