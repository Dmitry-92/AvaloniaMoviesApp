<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AvaloniaMoviesApp.Models"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="AvaloniaMoviesApp.Views.MainWindow"
        Title="Библиотека фильмов"
        Width="900" Height="600"
        MinWidth="700" MinHeight="500">

    <DockPanel>
        <!-- Верхняя панель с кнопками -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10" Spacing="10">
            <Button Name="AddButton" Content="➕ Добавить фильм" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="EditButton" Content="✏️ Редактировать" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="DeleteButton" Content="🗑️ Удалить" HorizontalAlignment="Left" MinWidth="120"/>
            <Button Name="RefreshButton" Content="🔄 Обновить" HorizontalAlignment="Left" MinWidth="100"/>
        </StackPanel>

        <!-- Список фильмов в виде ListBox -->
        <ListBox Name="MoviesListBox" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="models:Movie">
                    <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="10" Margin="0,2">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Text="{Binding Id}" Width="50" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Title}" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding Year}" Width="60"/>
                                <TextBlock Text="{Binding Rating}" Width="60"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>